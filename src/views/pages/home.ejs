<div class="container-100">

    <%- include("../partials/title") %>

        <div class="category-container">
            <div class="app-user">
                <%- include("../partials/user") %>
                <button class="button logout" type="button">
                    <img class="button__logout" src="/icons/log-out.png" alt="logout">
                </button>
            </div>
            <div class="category-window">
                <h2 class="category__title">Categories</h2>

                <form class="form form--create-category" id="create-category" method="POST">
                    <h3 class="form__title">New category</h3>
                    <div class="form__field">
                        <label class="form__label">Category name</label>
                        <input class="form__input" type="text" placeholder="e.g. Work, Personal…" required>
                    </div>
                    <div class="form__actions">
                        <button class="form__btn form__btn--cancel" id="cancel-create-category" type="button">Cancel</button>
                        <button class="form__btn form__btn--submit" id="create-category">Create</button>
                    </div>
                </form>

                <div class="category__list-container">

                </div>
                <button class="category__list-item-add"> + Category</button>
            </div>
        </div>
</div>

<div class="task-window">

    <button class="button logout account__logout" type="button">Logout</button>

    <div class="task-window__category-bg">
        <img class="category-bg__image" src="/images/bg_rotated.jpg" alt="backgroudn image">
        <h2 class="category-bg__title">All tasks</h2>
    </div>


    <h2 class="task-status">Pending</h2>

    <dialog class="dialog" id="delete-dialog">
        <h3 class="dialog__title">Delete item</h3>
        <p class="dialog__message">Are you sure you want to delete this? This cannot be undone.</p>
        <div class="dialog__actions">
            <button class="dialog__btn dialog__btn--cancel" id="close-dialog">Cancel</button>
            <button class="dialog__btn dialog__btn--danger" id="confirm-delete">Delete</button>
        </div>
    </dialog>

    <dialog class="dialog" id="logout-dialog">
        <h3 class="dialog__title">Log out</h3>
        <p class="dialog__message">Are you sure you want to log out?</p>
        <div class="dialog__actions">
            <button class="dialog__btn dialog__btn--cancel" id="cancel-logout">Stay</button>
            <button class="dialog__btn dialog__btn--neutral" id="confirm-logout">Log out</button>
        </div>
    </dialog>
    <section class="tasks-container pending">

    </section>

    <form class="form form--create-task" id="form-task" method="POST">

    </form>

    <div class="add-task-container">
        <button class="btn-add-task">+</button>
    </div>

    <h2 class="task-status">Done</h2>
    <section class="tasks-container completed">

    </section>
</div>