<div class="auth-card">
    <div class="auth-brand">
        <div class="auth-brand__name">Tracking Marker</div>
        <div class="auth-brand__tagline">Keep track of what matters</div>
    </div>

    <h2 class="auth-title">Welcome back</h2>

    <%- include('../partials/form-errors') %>

    <form class="auth__form" method="post" action="login">
        <% locals.inputs?.forEach(input => { %>
            <%- include('../partials/form-input', input) %>
        <% }); %>

        <div class="auth-footer">
            <input type="submit" class="btn btn--submit" value="Login">
            <a class="auth-link" href="/register">Create account</a>
        </div>
    </form>
</div>
