<div class="input-container">
    <label for="<%= name %>"><%= label %></label>
    <% if (type === "textarea") { %>
        <textarea id="<%= name %>" name="<%= name %>"><%= locals.value %></textarea>
    <% } else { %>
        <input id="<%= name %>" type="<%= type %>" name="<%= name %>" value="<%= locals.value %>">
    <% } %>
    <% if (locals.err) { %>
        <span class="input-error"><%= err %></span>
    <% } %>
</div>
